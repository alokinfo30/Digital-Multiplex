# OpenRouter AI Configuration
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_APP_NAME="DigitalMultiplex"

# --- Model Selection (Optional - Will use primary model if not set) ---
OPENROUTER_PRIMARY_MODEL="openai/gpt-4o-mini"
OPENROUTER_FALLBACK_MODELS="mistralai/mixtral-8x22b-instruct,meta-llama/llama-3.1-8b-instruct"

CONTENT_CURATOR_MODEL="openai/gpt-4o-mini"
MOVIE_GENERATOR_MODEL="openai/gpt-4o-mini"
SONG_GENERATOR_MODEL="mistralai/mixtral-8x22b-instruct"
RADIO_GENERATOR_MODEL="meta-llama/llama-3.1-8b-instruct"
DOCUMENTARY_GENERATOR_MODEL="meta-llama/llama-3.1-8b-instruct"
PODCAST_GENERATOR_MODEL="deepseek/deepseek-chat"
TRANSLATOR_MODEL="deepseek/deepseek-chat"

# Flask App Configuration
FLASK_APP="run.py"
FLASK_ENV="development" # Use "production" in production
SECRET_KEY="a-very-strong-and-random-secret-key"
DEBUG=True # Use False in production

# Database
DATABASE_URL="sqlite:///data/multiplex.db"

# TMDB API (Optional)
USE_TMDB=True
TMDB_API_KEY="your_tmdb_api_key"

# Translation
TRANSLATION_PROVIDER="libre"
SUPPORTED_LANGUAGES="en,hi,es,fr,de,zh,ja,ko,pt,ru,it"

# Security
SESSION_COOKIE_SECURE=False # Use True in production if using HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE="Lax"